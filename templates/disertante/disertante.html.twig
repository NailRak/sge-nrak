<h1>{{ disertante.nombreCompleto }}</h1>

<p>{{ disertante.biografia }}</p>

<p>
    <strong>Teléfono:</strong>
    {{ disertante.telefono }}
</p>

<p>
    <strong>Página:</strong>
    {{ disertante.url }}
</p>

<p>
    <strong>Imparte los siguientes eventos:</strong>
</p>

<ul>

{% for evento in disertante.eventos %}

    <li>

        <a href="{{ path('app_evento_detalle', {
            'slug': evento.slug
        }) }}">
            {{ evento.titulo }}
        </a>

    </li>

{% else %}

    <li>No posee eventos asignados</li>

{% endfor %}

</ul>
