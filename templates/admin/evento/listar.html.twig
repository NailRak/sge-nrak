{% extends 'base.html.twig' %}

{% block title %}
    Gestión de Eventos
{% endblock %}

{% block body %}

<div class="container mt-4">

    <h1>Gestión de Eventos</h1>

    <table class="table table-bordered table-striped">

        <thead>
        <tr>
            <th>Fecha/Hora</th>
            <th>Título</th>
            <th>Idioma</th>
            <th>Inscriptos</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
        </thead>

        <tbody>

        {% for evento in eventos %}

            <tr>

                <td>
                    {{ evento.fecha|date('d/m/Y') }}
                    {{ evento.hora|date('H:i') }}
                </td>

                <td>
                    {{ evento.titulo }}
                </td>

                <td>
                    {{ evento.idioma }}
                </td>

                <td>
                    {{ evento.usuarios|length }}
                </td>

                
                 
          <td>
        {% if evento.fecha < date() %}
        <span class="badge bg-secondary">Finalizado</span>

      {% elseif evento.fecha|date('Y-m-d') == date()|date('Y-m-d') %}
        <span class="badge bg-warning text-dark">Activo</span>

       {% else %}
        <span class="badge bg-success">Activo</span>
       {% endif %}
       </td>

                <td>
                    <a href="#"
                       class="btn btn-info btn-sm">
                        👥 Inscriptos
                    </a>

                    <a href="#"
                       class="btn btn-danger btn-sm">
                        🗑️ Borrar
                    </a>

                </td>

            </tr>

        {% else %}

            <tr>
                <td colspan="5">
                    No existe ningún evento.
                </td>
            </tr>

        {% endfor %}

        </tbody>

    </table>

    <a href="#"
       class="btn btn-success">
        ➕ Nuevo Evento
    </a>

</div>

{% endblock %}